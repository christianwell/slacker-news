---
interface Props {
  manifestUrl: string;
}

const { manifestUrl } = Astro.props;
---

<section class="article-reader" aria-label="Article reader" data-manifest-url={manifestUrl}>
  <button
    type="button"
    data-reader-toggle
    data-state="loading"
    aria-label="Loading article audio"
    title="Loading article audio"
    disabled
  >
    <svg class="play-icon" viewBox="0 0 12 14" aria-hidden="true">
      <path d="M1 1.2v11.6L11 7 1 1.2Z"></path>
    </svg>
    <svg class="pause-icon" viewBox="0 0 12 14" aria-hidden="true">
      <path d="M1.5 1h3v12h-3zM7.5 1h3v12h-3z"></path>
    </svg>
  </button>
  <p class="article-reader-details">
    <span data-reader-status aria-live="polite">Loading article audio…</span>
    <span aria-hidden="true"> &middot; </span>
    <span data-reader-voice>Loading voice…</span>
  </p>
</section>

<script>
  const reader = document.querySelector<HTMLElement>(".article-reader");
  const article = document.querySelector<HTMLElement>("#story-body");

  if (reader && article) {
    const toggleButton = reader.querySelector<HTMLButtonElement>("[data-reader-toggle]")!;
    const statusText = reader.querySelector<HTMLElement>("[data-reader-status]")!;
    const voiceText = reader.querySelector<HTMLElement>("[data-reader-voice]")!;

    let isReading = false;
    let isPaused = false;
    let highlightedWord: HTMLElement | undefined;
    let wordElements: HTMLElement[] = [];
    let activeAudio: HTMLAudioElement | undefined;
    let highlightFrame: number | undefined;
    let currentChunk = 0;
    let speechRun = 0;

    interface TimedWord {
      word: string;
      start: number;
      end: number;
    }

    interface AudioManifest {
      voice: string;
      chunks: Array<{ audio: string; words: TimedWord[] }>;
    }

    const manifestUrl = reader.dataset.manifestUrl!;
    let manifest: AudioManifest | undefined;
    let mappedWords: Array<HTMLElement | undefined>[] = [];
    const excludedContent =
      "figcaption, .caption, button, [role='button'], [aria-hidden='true'], [data-speech-ignore], script, style, noscript, svg";

    function prepareArticle() {
      if (wordElements.length > 0) return;

      const walker = document.createTreeWalker(article, NodeFilter.SHOW_TEXT, {
        acceptNode(node) {
          const parent = node.parentElement;
          if (!parent || parent.closest(excludedContent) || !node.textContent?.trim()) {
            return NodeFilter.FILTER_REJECT;
          }
          return NodeFilter.FILTER_ACCEPT;
        },
      });
      const textNodes: Text[] = [];
      while (walker.nextNode()) textNodes.push(walker.currentNode as Text);

      for (const textNode of textNodes) {
        const fragment = document.createDocumentFragment();
        for (const part of (textNode.textContent ?? "").split(/(\s+)/)) {
          if (!part) continue;
          if (/^\s+$/.test(part)) {
            fragment.append(part);
            continue;
          }

          const word = document.createElement("span");
          word.className = "article-reader-word";
          word.textContent = part;
          wordElements.push(word);
          fragment.append(word);
        }
        textNode.replaceWith(fragment);
      }
    }

    function clearHighlight() {
      highlightedWord?.classList.remove("article-reader-word-active");
      highlightedWord = undefined;
    }

    function highlight(word: HTMLElement | undefined) {
      if (word && word !== highlightedWord) {
        clearHighlight();
        highlightedWord = word;
        word.classList.add("article-reader-word-active");
      }
    }

    function clearHighlightFrame() {
      if (highlightFrame !== undefined) window.cancelAnimationFrame(highlightFrame);
      highlightFrame = undefined;
    }

    function normalized(word: string) {
      return word.toLocaleLowerCase("en").replace(/[^\p{L}\p{N}]/gu, "");
    }

    function mapManifestWords() {
      prepareArticle();
      const elements = wordElements.map((element) => normalized(element.textContent ?? ""));
      let elementIndex = 0;
      mappedWords = manifest!.chunks.map((chunk) => chunk.words.map(({ word }) => {
        const target = normalized(word);
        const match = elements.indexOf(target, elementIndex);
        if (match < 0) return undefined;
        elementIndex = match + 1;
        return wordElements[match];
      }));
    }

    function updateHighlight(audio: HTMLAudioElement, chunkIndex: number) {
      if (audio !== activeAudio || audio.paused) return;
      const words = manifest!.chunks[chunkIndex].words;
      const wordIndex = words.findLastIndex((word) => word.start <= audio.currentTime);
      if (
        wordIndex >= 0 &&
        (wordIndex < words.length - 1 || audio.currentTime <= words[wordIndex].end)
      ) {
        highlight(mappedWords[chunkIndex][wordIndex]);
      } else {
        clearHighlight();
      }
      highlightFrame = window.requestAnimationFrame(() => updateHighlight(audio, chunkIndex));
    }

    function setStoppedState(status: string) {
      isReading = false;
      isPaused = false;
      clearHighlightFrame();
      clearHighlight();
      activeAudio?.pause();
      activeAudio = undefined;
      setToggleButton("Listen", "play");
      toggleButton.disabled = !manifest;
      statusText.textContent = status;
    }

    function setToggleButton(label: string, state: "play" | "pause" | "loading") {
      toggleButton.dataset.state = state;
      toggleButton.setAttribute("aria-label", label);
      toggleButton.title = label;
    }

    async function playChunk(index: number, currentRun: number): Promise<void> {
      if (!manifest || currentRun !== speechRun || index >= manifest.chunks.length) return;
      currentChunk = index;
      const chunk = manifest.chunks[index];
      const audio = new Audio(new URL(chunk.audio, new URL(manifestUrl, window.location.href)).href);
      activeAudio = audio;
      toggleButton.disabled = true;
      setToggleButton("Loading article audio", "loading");
      statusText.textContent = "Loading article audio…";

      await new Promise<void>((resolve, reject) => {
        audio.addEventListener("ended", () => resolve(), { once: true });
        audio.addEventListener("error", () => reject(new Error("Audio failed to load")), { once: true });
        audio.addEventListener("waiting", () => {
          if (audio !== activeAudio || isPaused) return;
          clearHighlightFrame();
          toggleButton.disabled = true;
          setToggleButton("Loading article audio", "loading");
          statusText.textContent = "Loading article audio…";
        });
        audio.addEventListener("playing", () => {
          if (audio !== activeAudio || isPaused) return;
          clearHighlightFrame();
          toggleButton.disabled = false;
          setToggleButton("Pause", "pause");
          statusText.textContent = "Reading article";
          updateHighlight(audio, index);
        });
        void audio.play().catch(reject);
      });
      if (currentRun === speechRun) await playChunk(index + 1, currentRun);
    }

    function startReading() {
      if (!manifest?.chunks.length) {
        statusText.textContent = "No article text available";
        return;
      }
      speechRun += 1;
      const currentRun = speechRun;
      clearHighlightFrame();
      activeAudio?.pause();
      activeAudio = undefined;
      isReading = true;
      isPaused = false;

      void playChunk(0, currentRun)
        .then(() => {
          if (currentRun === speechRun) setStoppedState("Finished reading article");
        })
        .catch(() => {
          if (currentRun === speechRun) setStoppedState("Unable to read article");
        });
    }

    toggleButton.addEventListener("click", () => {
      if (!isReading) {
        startReading();
        return;
      }

      if (isPaused) {
        void activeAudio?.play();
        isPaused = false;
        setToggleButton("Pause", "pause");
        statusText.textContent = "Reading article";
        if (activeAudio) updateHighlight(activeAudio, currentChunk);
      } else {
        activeAudio?.pause();
        clearHighlightFrame();
        isPaused = true;
        setToggleButton("Resume", "play");
        statusText.textContent = "Paused";
      }
    });

    void fetch(manifestUrl)
      .then((response) => {
        if (!response.ok) throw new Error("Article audio is unavailable");
        return response.json() as Promise<AudioManifest>;
      })
      .then((loadedManifest) => {
        manifest = loadedManifest;
        mapManifestWords();
        voiceText.textContent = manifest.voice;
        setToggleButton("Listen", "play");
        toggleButton.disabled = false;
        statusText.textContent = "Ready to listen";
      })
      .catch(() => {
        setToggleButton("Listen", "play");
        voiceText.textContent = "Unavailable";
        statusText.textContent = "Article audio unavailable";
      });
  }
</script>

<style>
  .article-reader {
    display: none;
    align-items: center;
    margin-right: 0.5rem;
    vertical-align: middle;
  }

  :global(html.js) .article-reader {
    display: inline-flex;
  }

  .article-reader-details {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  button {
    position: relative;
    display: inline-grid;
    place-items: center;
    width: 1.5rem;
    height: 1.5rem;
    padding: 0;
    border: 1px solid #000;
    border-radius: 50%;
    background: transparent;
    color: #111;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  button:hover:not(:disabled) {
    background: #fff;
  }

  button:focus-visible {
    outline: 2px solid #000;
    outline-offset: 3px;
  }

  button:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  button[data-state="loading"] {
    cursor: wait;
    opacity: 1;
  }

  button[data-state="loading"]::before {
    position: absolute;
    inset: -0.25rem;
    border: 2px solid #168bd2;
    border-right-color: transparent;
    border-radius: 50%;
    content: "";
    animation: reader-loading 0.7s linear infinite;
  }

  svg {
    width: 0.5rem;
    height: 0.625rem;
    fill: currentColor;
  }

  :global(html.dark-mode) .article-reader svg,
  :global(html:not(.light-mode):not(.dark-mode)) .article-reader svg {
    filter: none;
  }

  .play-icon {
    margin-left: 0.1rem;
  }

  .pause-icon,
  button[data-state="pause"] .play-icon,
  button[data-state="loading"] .play-icon {
    display: none;
  }

  button[data-state="pause"] .pause-icon,
  button[data-state="loading"] .pause-icon {
    display: block;
  }

  @keyframes reader-loading {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    button[data-state="loading"]::before {
      animation-duration: 1.5s;
    }
  }

  :global(#story-body .article-reader-word-active) {
    border-radius: 3px;
    background: #ffe066;
    box-shadow: 0 0 0 2px #ffe066;
    transition: background 0.08s ease;
  }

</style>
